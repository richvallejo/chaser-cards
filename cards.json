    "stage_questions": {
      "context": "What are we hunting for, and why does it matter?",
      "hypothesis": "What do we believe may be happening in the environment?",
      "analyze": "What evidence do we need to examine?",
      "strategize": "How are we going to run the hunt?",
      "execute": "What do we do with what we found?",
      "review": "What did we learn, and what should change?"
    },
    "stage_purposes": {
      "context": "Relevant CVEs, techniques, affected systems, known behaviors, likely impact, and indicators.",
      "hypothesis": "A testable statement that identifies likely behavior, affected environment, and evidence that would support or challenge the hunt.",
      "analyze": "Telemetry and evidence sources needed to confirm, weaken, or disprove the hypothesis, including visibility gaps.",
      "strategize": "Scope, time window, affected assets, search logic, pivots, enrichment, expected results, false positives, and decision points.",
      "execute": "Finding-based actions such as documenting results, remediation, escalation, detection tuning, reporting, or incident response.",
      "review": "Lessons learned and improvements to detections, controls, telemetry, documentation, playbooks, and future hunt cards."
    }
  },
